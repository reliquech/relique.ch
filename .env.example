# Copy to .env.local and fill in real values:
#   cp .env.example .env.local
#
# Unified app — npm run dev (port 1300)

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:1300

# Supabase — Project Settings → API
# Local dev: use the direct project URL (recommended):
#   NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# If you use a Cloudflare Tunnel hostname instead, cloudflared must be running
# or every /api/* route that hits Supabase will fail with tunnel error 1033.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# SEO — optional
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
