# Copy to `.env.local` for local development (never commit secrets).

# Site
NEXT_PUBLIC_SITE_URL=http://localhost:1300

# Supabase — production MUST use HTTPS (e.g. https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Legacy (optional fallback until Vercel/local env is updated):
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Vercel production checklist:
# - Project Settings → Root Directory: leave EMPTY (repo root). Do NOT use apps/web (removed in Phase 6).
# - Install Command: npm install | Build Command: npm run build (or use vercel.json at repo root)
# - NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# - NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# - SUPABASE_SECRET_KEY=sb_secret_... (server only, never expose to browser)
# - NEXT_PUBLIC_SITE_URL=https://relique.ch
